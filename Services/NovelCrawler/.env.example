# NovelCrawler/.env.example
# Copy from .env.example and fill in the values.
# Values marked [REQUIRED] must be set — the service will not start without them.

# -------------------------------------------------------------------
# REQUIRED — database connection string.
# -------------------------------------------------------------------
DATABASE_URL_FILE=/run/secrets/crawler_database_url
INTERNAL_SERVICE_TOKEN_FILE=/run/secrets/internal_service_token

# Local development may use direct env vars instead of *_FILE:
# DATABASE_URL=postgresql+psycopg://create_story_crawler:password@localhost:5432/create_story_crawler
# INTERNAL_SERVICE_TOKEN=dev-only-internal-token

# -------------------------------------------------------------------
# CORS — comma-separated list of allowed origins.
# -------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -------------------------------------------------------------------
# ScribbleHub — Cloudflare auto-solve.
# FlareSolverr solves the Cloudflare challenge from inside Docker and the crawler
# harvests the cf_clearance cookie automatically. In docker-compose this is already
# set to the internal service; only set it here when running NovelCrawler standalone
# against your own FlareSolverr instance.
# -------------------------------------------------------------------
# FLARESOLVERR_URL=http://flaresolverr:8191/v1
#
# Optional alternative to FlareSolverr for Docker runs (route ScribbleHub egress
# through a proxy on the host — run scripts/scribblehub_host_proxy.py first):
# SCRIBBLEHUB_PROXY_URL=http://host.docker.internal:8899
#
# ScribbleHub rate-limits per IP (HTTP 429). The crawler auto-retries rate-limited
# chapters in rounds (with cooldowns) so a full novel always completes. Tune:
# SCRIBBLEHUB_DOWNLOAD_DELAY=0.35   # seconds between chapter requests (raise to reduce 429s)
# SCRIBBLEHUB_RETRY_COOLDOWN=45     # seconds before each retry round
# SCRIBBLEHUB_RETRY_ROUNDS=40       # max retry rounds before giving up

# -------------------------------------------------------------------
# Inkitt batch discovery — production IPs can be rate-limited by Inkitt (HTTP 429).
# The batch page's "Delay seconds" controls the minimum delay between Inkitt
# requests; these values control cooldown/retry behavior when a genre page returns 429.
# -------------------------------------------------------------------
# INKITT_BATCH_MAX_DISCOVER_WORKERS=2
# INKITT_BATCH_MAX_CRAWL_WORKERS=4
# INKITT_DISCOVER_RETRY_TIMES=6
# INKITT_DISCOVER_RETRY_BASE_SECONDS=15
# INKITT_DISCOVER_RETRY_MAX_SECONDS=120
# INKITT_RENDERED_FALLBACK=1
# INKITT_RENDERED_FALLBACK_SUSPICIOUS_WORDS=800
#
# Recommended production behavior for large Inkitt catalogs:
# - Four workers with a 1 second delay use one serialized request lane. Repeated
#   HTTP 429 responses trigger automatic global cooldowns instead of failed rows.
# INKITT_GLOBAL_MIN_REQUEST_INTERVAL_SECONDS=1.0
# INKITT_MAX_IN_FLIGHT_REQUESTS=2
# INKITT_RATE_LIMIT_BASE_COOLDOWN_SECONDS=60
# INKITT_RATE_LIMIT_MAX_COOLDOWN_SECONDS=900
# INKITT_RATE_LIMIT_MAX_EVENTS=8
# INKITT_RATE_LIMIT_RECOVERY_SUCCESSES=250
# INKITT_ARCHIVE_PREPARE_DELAY_SECONDS=120
# INKITT_ARCHIVE_COMPRESSION_LEVEL=1
# - Crawl in small runs (for example 50-200 stories) and use pause/resume.
# - Treat HTTP 429/403 as a signal to slow down or wait before resuming.
# - Cloudflare Tunnel protects inbound access to this app, but outbound requests
#   from novel_crawler to Inkitt use the server/container's normal egress route.

# Jobnib completed-story batch defaults. Slow is selected by the UI unless the
# operator explicitly starts a Fast run. Partial or preview chapters are rejected.
JOBNIB_ALLOW_PARTIAL=false
JOBNIB_MIN_CHAPTER_WORDS=100
JOBNIB_BATCH_MAX_ARCHIVE_PAGES=1
JOBNIB_BATCH_MAX_STORIES=10000
JOBNIB_DISCOVERY_INTERVAL_SECONDS=1.5
JOBNIB_SLOW_STORY_WORKERS=1
JOBNIB_SLOW_REQUEST_SLOTS=2
JOBNIB_SLOW_REQUEST_INTERVAL_SECONDS=1.5
JOBNIB_FAST_STORY_WORKERS=2
JOBNIB_FAST_REQUEST_SLOTS=4
JOBNIB_FAST_REQUEST_INTERVAL_SECONDS=0.75
JOBNIB_ARCHIVE_PREPARE_DELAY_SECONDS=120
JOBNIB_ARCHIVE_COMPRESSION_LEVEL=1
JOBNIB_USE_COOKIES=true
JOBNIB_HEADLESS=true
# Compose fixes this beneath the existing novel_crawler_output volume.
JOBNIB_CHROME_PROFILE=/app/output/jobnib_browser_profile
