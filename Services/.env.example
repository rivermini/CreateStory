# Non-secret local deployment settings for Docker Compose.
# Copy to .env if you need to override defaults. Do not put secrets here.

# Browser origins that may call the gateway. The default in docker-compose.yml
# already includes the local dev frontend and the real Cloudflare frontend route.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://createstory.online

# Deployment environment. "production" hard-disables the destructive Dev Cleanup
# routes (regardless of DEV_MODE) and enables strict security headers. Defaults
# to "development" if unset. Set to "production" on the live server.
ENVIRONMENT=production

# Inkitt batch crawling: request starts are globally paced and slow responses
# may overlap up to the bounded in-flight limit. HTTP 429 drops that limit to 1.
INKITT_BATCH_MAX_CRAWL_WORKERS=4
INKITT_GLOBAL_MIN_REQUEST_INTERVAL_SECONDS=1.0
INKITT_MAX_IN_FLIGHT_REQUESTS=2
INKITT_RATE_LIMIT_BASE_COOLDOWN_SECONDS=60
INKITT_RATE_LIMIT_MAX_COOLDOWN_SECONDS=900
INKITT_RATE_LIMIT_MAX_EVENTS=8
INKITT_RATE_LIMIT_RECOVERY_SUCCESSES=250
INKITT_ARCHIVE_PREPARE_DELAY_SECONDS=120
INKITT_ARCHIVE_COMPRESSION_LEVEL=1

# NovelHall genre batch crawling: discovery scrapes NovelHall genre HTML through
# the NovelHall spider (Cloudflare solved once via FlareSolverr, then replayed).
# Request starts are globally paced with a bounded number of responses in flight.
NOVELHALL_BATCH_MAX_DISCOVER_WORKERS=2
NOVELHALL_BATCH_MAX_CRAWL_WORKERS=6
NOVELHALL_DISCOVER_RETRY_TIMES=6
NOVELHALL_DISCOVER_RETRY_BASE_SECONDS=15
NOVELHALL_DISCOVER_RETRY_MAX_SECONDS=120
NOVELHALL_GLOBAL_MIN_REQUEST_INTERVAL_SECONDS=0.1
NOVELHALL_MAX_IN_FLIGHT_REQUESTS=8
NOVELHALL_RATE_LIMIT_BASE_COOLDOWN_SECONDS=60
NOVELHALL_RATE_LIMIT_MAX_COOLDOWN_SECONDS=900
NOVELHALL_RATE_LIMIT_MAX_EVENTS=8
NOVELHALL_RATE_LIMIT_RECOVERY_SUCCESSES=250
NOVELHALL_ARCHIVE_PREPARE_DELAY_SECONDS=120
NOVELHALL_ARCHIVE_COMPRESSION_LEVEL=1

# ReadNovelMtl discovery batch crawling: discovery scrapes the site's "Latest"
# listing plus its 4 ranking pages through the ReadNovelMtl spider (Cloudflare
# solved once via FlareSolverr, then replayed). Same pacing/archive knobs as NovelHall.
READNOVELMTL_BATCH_MAX_DISCOVER_WORKERS=2
READNOVELMTL_BATCH_MAX_CRAWL_WORKERS=6
READNOVELMTL_DISCOVER_RETRY_TIMES=6
READNOVELMTL_DISCOVER_RETRY_BASE_SECONDS=15
READNOVELMTL_DISCOVER_RETRY_MAX_SECONDS=120
READNOVELMTL_GLOBAL_MIN_REQUEST_INTERVAL_SECONDS=0.1
READNOVELMTL_MAX_IN_FLIGHT_REQUESTS=8
# Optional cf_clearance warmer, default OFF. ReadNovelMtl throttles the IP after ~150 fast
# requests (cookies don't bypass it); chunked runs with a cooldown are the real fix. >0 enables.
READNOVELMTL_COOKIE_WARM_INTERVAL_SECONDS=0
READNOVELMTL_RATE_LIMIT_BASE_COOLDOWN_SECONDS=60
READNOVELMTL_RATE_LIMIT_MAX_COOLDOWN_SECONDS=900
READNOVELMTL_RATE_LIMIT_MAX_EVENTS=8
READNOVELMTL_RATE_LIMIT_RECOVERY_SUCCESSES=250
READNOVELMTL_ARCHIVE_PREPARE_DELAY_SECONDS=120
READNOVELMTL_ARCHIVE_COMPRESSION_LEVEL=1
DOWNLOAD_TICKET_TTL_SECONDS=3600
DOWNLOAD_PREPARE_TIMEOUT_SECONDS=1800

# Bounded DriveSync processing. These defaults allow a 200-story batch to
# queue durably while only two stories and limited nested work execute at once.
DRIVE_SYNC_JOB_WORKERS=2
DRIVE_SYNC_CHAPTER_PREFETCH_WORKERS=4
DRIVE_SYNC_CHAPTER_WINDOW_SIZE=8
DRIVE_SYNC_DRIVE_CONCURRENCY=6
DRIVE_SYNC_METADATA_WORKERS=8
DRIVE_SYNC_METADATA_DOWNLOAD_CONCURRENCY=8

# --- Jobnib completed-story batches ---
JOBNIB_ALLOW_PARTIAL=false
JOBNIB_MIN_CHAPTER_WORDS=100
JOBNIB_BATCH_MAX_ARCHIVE_PAGES=1
JOBNIB_BATCH_MAX_STORIES=10000
JOBNIB_DISCOVERY_INTERVAL_SECONDS=1.5
JOBNIB_SLOW_STORY_WORKERS=1
JOBNIB_SLOW_REQUEST_SLOTS=2
JOBNIB_SLOW_REQUEST_INTERVAL_SECONDS=1.5
JOBNIB_FAST_STORY_WORKERS=2
JOBNIB_FAST_REQUEST_SLOTS=4
JOBNIB_FAST_REQUEST_INTERVAL_SECONDS=0.75
JOBNIB_ARCHIVE_PREPARE_DELAY_SECONDS=120
JOBNIB_ARCHIVE_COMPRESSION_LEVEL=1
JOBNIB_USE_COOKIES=true
JOBNIB_HEADLESS=true
# Optional absolute or NovelCrawler-relative path to the published standalone
# Windows companion. The default is tools/jobnib_browser_assistant/dist/CreateStory-Jobnib-Companion-win-x64.exe.
# Build it before the NovelCrawler Docker image: task build:jobnib-companion
# JOBNIB_COMPANION_PATH=tools/jobnib_browser_assistant/dist/CreateStory-Jobnib-Companion-win-x64.exe

# --- Auto Mode / TTS (BedReadVoices) throughput ---
# Kokoro TTS is the only CPU-heavy service; Auto Mode drives it. It scales fine
# on CPU (this is how ~1000 chapters/day was achieved) — the previous slowdown
# was purely the container being hard-capped to 2 cores. Size these to the host.
# Invariant:  KOKORO_CONCURRENCY * KOKORO_INTRA_OP_THREADS  ==  VOICES_CPUS
# (so the workers together use the whole granted budget without oversubscribing).
#
# CPU cap for the voices container (cores). Set to (usable cores - 1~2).
#   i5-12400 (6 cores / 12 threads):   VOICES_CPUS=10
#   8-core dev VM:                     VOICES_CPUS=6
# HARD PREREQUISITE (Docker Desktop / Windows): this must be <= the number of
# CPUs the Docker Desktop VM is allocated, or the container refuses to start
# ("range of CPUs is from 0.01 to N.00"). Check Docker Desktop > Settings >
# Resources > CPUs (WSL2: %UserProfile%\.wslconfig 'processors=') and raise the
# VM to ~all host threads FIRST — a low VM CPU count silently throttles Auto Mode
# no matter what this is set to.
VOICES_CPUS=10.0
# Voices container memory ceiling. Raise if large Auto Mode batches OOM.
VOICES_MEMORY=4g
# Chapters synthesized in parallel (overrides the persisted UI value).
KOKORO_CONCURRENCY=2
# Upper bound KOKORO_CONCURRENCY may reach.
KOKORO_MAX_CONCURRENCY=4
# ONNX intra-op threads PER worker = VOICES_CPUS / KOKORO_CONCURRENCY.
#   VOICES_CPUS=10, KOKORO_CONCURRENCY=2  ->  KOKORO_INTRA_OP_THREADS=5
#   Prefer max single-chapter speed instead? KOKORO_CONCURRENCY=1, threads=VOICES_CPUS.
#   Set KOKORO_INTRA_OP_THREADS=0 to leave ORT unpinned (uses all granted cores
#   per session — matches the original uncapped behavior, mild oversubscription).
KOKORO_INTRA_OP_THREADS=5
#
# GPU is NOT required. If a host ever does have an NVIDIA GPU you can go further
# by switching BedReadVoices/requirements.txt to onnxruntime-gpu + kokoro-onnx[gpu]
# and exposing the GPU — but on this CPU, the cap lift alone restores throughput.
