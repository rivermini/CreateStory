# Non-secret local deployment settings for Docker Compose.
# Copy to .env if you need to override defaults. Do not put secrets here.

# Browser origins that may call the gateway. The default in docker-compose.yml
# already includes the local dev frontend and the real Cloudflare frontend route.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://createstory.online

# Deployment environment. "production" hard-disables the destructive Dev Cleanup
# routes (regardless of DEV_MODE) and enables strict security headers. Defaults
# to "development" if unset. Set to "production" on the live server.
ENVIRONMENT=production

# Bounded DriveSync processing. These defaults allow a 200-story batch to
# queue durably while only two stories and limited nested work execute at once.
DRIVE_SYNC_JOB_WORKERS=2
DRIVE_SYNC_CHAPTER_PREFETCH_WORKERS=4
DRIVE_SYNC_CHAPTER_WINDOW_SIZE=8
DRIVE_SYNC_DRIVE_CONCURRENCY=6
DRIVE_SYNC_METADATA_WORKERS=8
DRIVE_SYNC_METADATA_DOWNLOAD_CONCURRENCY=8

# --- Auto Mode / TTS (BedReadVoices) throughput ---
# Kokoro TTS is the only CPU-heavy service; Auto Mode drives it. It scales fine
# on CPU (this is how ~1000 chapters/day was achieved) — the previous slowdown
# was purely the container being hard-capped to 2 cores. Size these to the host.
# Invariant:  KOKORO_CONCURRENCY * KOKORO_INTRA_OP_THREADS  ==  VOICES_CPUS
# (so the workers together use the whole granted budget without oversubscribing).
#
# CPU cap for the voices container (cores). Set to (usable cores - 1~2).
#   i5-12400 (6 cores / 12 threads):   VOICES_CPUS=10
#   8-core dev VM:                     VOICES_CPUS=6
# HARD PREREQUISITE (Docker Desktop / Windows): this must be <= the number of
# CPUs the Docker Desktop VM is allocated, or the container refuses to start
# ("range of CPUs is from 0.01 to N.00"). Check Docker Desktop > Settings >
# Resources > CPUs (WSL2: %UserProfile%\.wslconfig 'processors=') and raise the
# VM to ~all host threads FIRST — a low VM CPU count silently throttles Auto Mode
# no matter what this is set to.
VOICES_CPUS=10.0
# Voices container memory ceiling. Raise if large Auto Mode batches OOM.
VOICES_MEMORY=4g
# Chapters synthesized in parallel (overrides the persisted UI value).
KOKORO_CONCURRENCY=2
# Upper bound KOKORO_CONCURRENCY may reach.
KOKORO_MAX_CONCURRENCY=4
# ONNX intra-op threads PER worker = VOICES_CPUS / KOKORO_CONCURRENCY.
#   VOICES_CPUS=10, KOKORO_CONCURRENCY=2  ->  KOKORO_INTRA_OP_THREADS=5
#   Prefer max single-chapter speed instead? KOKORO_CONCURRENCY=1, threads=VOICES_CPUS.
#   Set KOKORO_INTRA_OP_THREADS=0 to leave ORT unpinned (uses all granted cores
#   per session — matches the original uncapped behavior, mild oversubscription).
KOKORO_INTRA_OP_THREADS=5
#
# GPU is NOT required. If a host ever does have an NVIDIA GPU you can go further
# by switching BedReadVoices/requirements.txt to onnxruntime-gpu + kokoro-onnx[gpu]
# and exposing the GPU — but on this CPU, the cap lift alone restores throughput.
