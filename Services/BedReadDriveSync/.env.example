# BedReadDriveSync/.env.example
# Copy to .env and fill in all values before starting the service.

# -------------------------------------------------------------------
# PostgreSQL connection string (REQUIRED — no default; service will
# refuse to start without this)
# -------------------------------------------------------------------
DATABASE_URL_FILE=/run/secrets/database_url
INTERNAL_SERVICE_TOKEN_FILE=/run/secrets/internal_service_token

# Local development may use direct env vars instead of *_FILE:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/create_story
# INTERNAL_SERVICE_TOKEN=dev-only-internal-token

# -------------------------------------------------------------------
# CORS allowed origins (comma-separated, no spaces)
# Default: http://localhost:5173,http://localhost:3000
# -------------------------------------------------------------------
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# -------------------------------------------------------------------
# Google Drive service account credentials JSON file path. Prefer a path
# outside the workspace or a Docker secret-mounted file.
# -------------------------------------------------------------------
# GOOGLE_SERVICE_ACCOUNT_JSON=/run/secrets/google_service_account_json

# -------------------------------------------------------------------
# Main BE API. The bearer token is provided through the gateway's
# X-Auth-Token header during config updates; it is not accepted in .env.
# -------------------------------------------------------------------
MAIN_BE_API_BASE_URL=https://api.example.com

# -------------------------------------------------------------------
# Optional: Default Drive folder ID (root folder to sync)
# -------------------------------------------------------------------
# DRIVE_FOLDER_ID=1ABCdefGhIJKlmnoPQRsTUVwxYZ
