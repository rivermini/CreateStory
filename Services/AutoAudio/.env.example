# AutoAudio/.env.example
# Copy from .env.example and fill in the values.

# -------------------------------------------------------------------
# REQUIRED — database and internal service authentication.
# -------------------------------------------------------------------
DATABASE_URL_FILE=/run/secrets/auto_audio_database_url
INTERNAL_SERVICE_TOKEN_FILE=/run/secrets/internal_service_token

# Local development may use direct env vars instead of *_FILE:
# DATABASE_URL=postgresql+psycopg://create_story_auto_audio:password@localhost:5432/create_story_auto_audio
# INTERNAL_SERVICE_TOKEN=dev-only-internal-token

# -------------------------------------------------------------------
# CORS — comma-separated list of allowed origins.
# -------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -------------------------------------------------------------------
# Service URLs — must match the JSON format used by process-compose.
# The process-compose.yml already passes these as environment variables,
# so you typically don't need to set them here unless running standalone.
# -------------------------------------------------------------------
SERVICE_URLS={"BedReadVoices":"http://localhost:8001","BedReadDriveSync":"http://localhost:8003"}

# -------------------------------------------------------------------
# Logging
# -------------------------------------------------------------------
LOG_LEVEL=INFO
