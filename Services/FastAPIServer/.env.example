# FastAPIServer/.env.example
# Copy to .env and fill in all values.
# This file documents every env var the server reads.
# Values marked [REQUIRED] must be set — the server will not start without them.

# -------------------------------------------------------------------
# REQUIRED — the server exits non-zero at startup if these are missing.
# -------------------------------------------------------------------
JWT_SECRET_KEY_FILE=/run/secrets/jwt_secret_key
INTERNAL_SERVICE_TOKEN_FILE=/run/secrets/internal_service_token

# -------------------------------------------------------------------
# REQUIRED — database connection string.
# -------------------------------------------------------------------
DATABASE_URL_FILE=/run/secrets/gateway_database_url

# -------------------------------------------------------------------
# CORS allowlist (comma-separated origins).
# Defaults to "http://localhost:5173,http://localhost:3000" if unset.
# -------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -------------------------------------------------------------------
# Service URLs — point to the microservice instances.
# -------------------------------------------------------------------
SERVICE_URLS.NovelCrawler=http://localhost:8002
SERVICE_URLS.BedReadVoices=http://localhost:8001
SERVICE_URLS.AutoAudio=http://localhost:8004
SERVICE_URLS.BedReadDriveSync=http://localhost:8003

# -------------------------------------------------------------------
# JWT auth — optional; defaults shown below.
# -------------------------------------------------------------------
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_MINUTES=30
# JWT_REFRESH_TOKEN_DAYS=14

# -------------------------------------------------------------------
# Bootstrap admin — optional; defaults shown below.
# -------------------------------------------------------------------
# BOOTSTRAP_ADMIN_EMAIL=admin@gmail.com
# BOOTSTRAP_ADMIN_PASSWORD_FILE=/run/secrets/bootstrap_admin_password

# -------------------------------------------------------------------
# Optional: External Main BE API (used by auto-audio orchestrator).
# -------------------------------------------------------------------
# MAIN_BE_API_BASE_URL=https://api.example.com
# MAIN_BE_API_TOKEN=your_token_here

# -------------------------------------------------------------------
# Optional: expose Swagger UI at /docs, /redoc, /openapi.json.
# Default: disabled. Set to "true" to enable (useful for debugging).
# -------------------------------------------------------------------
# ENABLE_DOCS=true
