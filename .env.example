# AutoAudio/.env.example
# Copy from .env.example and fill in the values.

# -------------------------------------------------------------------
# Service URLs — must match the JSON format used by process-compose.
# The process-compose.yml already passes these as environment variables,
# so you typically don't need to set them here unless running standalone.
# -------------------------------------------------------------------
SERVICE_URLS={"BedReadVoices":"http://localhost:8001","BedReadDriveSync":"http://localhost:8003"}

# -------------------------------------------------------------------
# Optional: Override paths to shared config files (relative to this
# service's root, or absolute paths).
# Defaults to ../../../FastAPIServer/data/
# -------------------------------------------------------------------
USER_SETTINGS_PATH=
DRIVE_SYNC_CONFIG_PATH=

# -------------------------------------------------------------------
# Logging
# -------------------------------------------------------------------
LOG_LEVEL=INFO
