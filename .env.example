# The app auto-detects the backend from the current hostname (see src/api/client.ts):
#   deployed domains -> same-origin /api (nginx proxies it to the gateway)
#   localhost        -> http://localhost:8000
# So you normally do NOT need to set anything here.
#
# Uncomment ONLY to force a specific gateway (overrides auto-detection; note an
# absolute URL reintroduces cross-origin CORS):
# VITE_API_BASE_URL=http://localhost:8000
