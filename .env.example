# NovelCrawler/.env.example
# Copy from .env.example and fill in the values.
# Values marked [REQUIRED] must be set — the service will not start without them.

# -------------------------------------------------------------------
# REQUIRED — database connection string.
# -------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/create_story

# -------------------------------------------------------------------
# CORS — comma-separated list of allowed origins.
# -------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
