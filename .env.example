# AutoAudio/.env
# Copy from .env.example and fill in the values.

# -------------------------------------------------------------------
# Service URLs — point to downstream microservices
# -------------------------------------------------------------------
SERVICE_URLS.BedReadVoices=http://localhost:8001
SERVICE_URLS.BedReadDriveSync=http://localhost:8003

# -------------------------------------------------------------------
# External Main BE API credentials (shared config — same as DriveSync)
# -------------------------------------------------------------------
# The path to the shared drive_sync_config.json file.
# If left empty, defaults to ../../../FastAPIServer/data/drive_sync_config.json
# relative to this service's root.
DRIVE_SYNC_CONFIG_PATH=

# -------------------------------------------------------------------
# User Settings — path to the shared user_settings.json file
# -------------------------------------------------------------------
# If left empty, defaults to ../../../FastAPIServer/data/user_settings.json
# relative to this service's root.
USER_SETTINGS_PATH=

# -------------------------------------------------------------------
# Logging
# -------------------------------------------------------------------
LOG_LEVEL=INFO
