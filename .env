# FastAPIServer/.env
# Generated from .env.example for Docker deployment.
# In Docker, DATABASE_URL uses the "postgres" hostname (Docker service name).
# JWT_SECRET_KEY must be set to a strong random value in production.

# REQUIRED — database connection string for Docker.
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/create_story

# REQUIRED — JWT signing secret. CHANGE THIS IN PRODUCTION to a long random string.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_USE_STRONG_SECRET_IN_PRODUCTION

# REQUIRED — bootstrap admin password.
# Defaults to +E8ep0m7(h5ut#Q$ if not set (for development convenience).
# CHANGE THIS IN PRODUCTION.

# CORS allowlist.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://createstory.online

# Service URLs (used by the gateway to route to other microservices).
SERVICE_URLS={"FastAPIServer":"http://fastapi_gateway:8000","NovelCrawler":"http://novel_crawler:8002","BedReadVoices":"http://bedread_voices:8001","AutoAudio":"http://auto_audio:8004","BedReadDriveSync":"http://bedread_drive_sync:8003"}
