# Path to the Kokoro ONNX model file (relative to project root or absolute)
KOKORO_MODEL_PATH=api/models/kokoro-v1.0.onnx

# Path to the Kokoro voices manifest file (relative to project root or absolute)
KOKORO_VOICES_PATH=api/models/voices-v1.0.bin

# ONNX execution provider: CUDAExecutionProvider (GPU) or CPUExecutionProvider (CPU).
# Leave empty to auto-detect (GPU preferred).
ONNX_PROVIDER=

# Number of concurrent TTS worker threads.
# Leave blank to auto-tune: 1 on CUDA, up to 4 on CPU.
KOKORO_CONCURRENCY=

# Target text characters per TTS chunk. Larger values reduce overhead.
KOKORO_CHUNK_SIZE=1400

# Write intermediate chunk_*.wav files for debugging only.
KOKORO_SAVE_CHUNKS=false

# Downstream service URLs
SERVICE_URLS_FastAPIServer=http://localhost:8000
SERVICE_URLS_BedReadVoices=http://localhost:8001
