# BedReadVoices/.env
# Generated from .env.example for Docker deployment.
# In Docker, DATABASE_URL uses the "postgres" hostname (Docker service name).

# REQUIRED — database connection string for Docker.
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/create_story

# CORS allowlist.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
